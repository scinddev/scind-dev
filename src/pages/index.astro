---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Scind" description="A workspace orchestration system for Docker Compose.">
  <main>
    <h1>Scind</h1>
    <p>A workspace orchestration system for Docker Compose.</p>
  </main>
</BaseLayout>

<style>
  main {
    max-width: 36rem;
    margin: 0 auto;
    padding: 6rem 1.5rem;
    text-align: center;
  }
  h1 {
    font-size: 2.5rem;
    font-weight: 500;
    margin: 0 0 1rem;
    letter-spacing: -0.015em;
  }
  p {
    margin: 0;
    color: #6b6b6b;
    font-size: 1.125rem;
    line-height: 1.6;
  }
</style>
